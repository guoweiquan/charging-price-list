page{font-family:-apple-system,BlinkMacSystemFont,PingFang SC,HarmonyOS Sans,Microsoft YaHei,sans-serif;background-color:#1a1a1a;color:gold;line-height:1.6;-webkit-text-size-adjust:100%;text-size-adjust:100%}text,view{-webkit-text-size-adjust:100%;text-size-adjust:100%}.text-gold{color:gold}.text-orange{color:#ff4500}.full-screen-bg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:-1}.bg-image{width:100%;height:100%;object-fit:cover}.glass-card{background:rgba(255,255,255,.1);backdrop-filter:blur(10rpx);-webkit-backdrop-filter:blur(10rpx);border:1rpx solid rgba(255,255,255,.2);box-shadow:0 8rpx 12rpx rgba(0,0,0,.1);border-radius:16rpx}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}